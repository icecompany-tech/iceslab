{
  "name": "iceslab",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-core proxy panel with native Hysteria2, AmneziaWG, and NaiveProxy support",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=5.0.7",
      "fast-uri": ">=3.1.4",
      "form-data": ">=4.0.6",
      "hono": ">=4.12.25"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  }
}
